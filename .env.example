# Copy to .env.local for local development (never commit .env or .env.local)
# Vercel: set these in Project Settings → Environment Variables.

# API base URL
# Local dev (Vite proxy): /api/v1.0
# Production: https://your-backend.onrender.com/api/v1.0
VITE_API_BASE_URL=/api/v1.0

# Razorpay public key only (never put the secret key in the frontend)
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
